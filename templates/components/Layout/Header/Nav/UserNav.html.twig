<div>
    <button type="button" class="flex text-sm rounded-full text-stone-400 dark:text-stone-600 bg-stone-100 dark:bg-stone-200 border border-stone-200 dark:border-stone-700 focus:ring-4 focus:ring-stone-100 dark:focus:ring-stone-400/20" aria-expanded="false" data-dropdown-toggle="dropdown-user">
        <span class="sr-only">Ouvrir menu utilisateur</span>
        <span class="w-8 h-8 flex items-center justify-center">
            <twig:ux:icon name="ph:user" class="w-5 h-5" />
        </span>
    </button>
</div>
<div class="z-50 hidden my-4 text-base list-none bg-stone-100 divide-y divide-stone-200 rounded-lg dark:bg-stone-800 dark:divide-stone-700 border border-stone-200 dark:border-stone-700" id="dropdown-user">
    <div class="flex flex-col items-center justify-center px-4 py-3" role="none">
        <span class="flex items-center justify-center w-15 h-15 p-4 mb-3 rounded-full font-black text-stone-700 bg-stone-200 border border-stone-300 dark:border-stone-500">
            {{ firstname|slice(0, 1) }} {{ lastname|slice(0, 1) }}
        </span>
        <p class="text-sm text-stone-800 dark:text-stone-200" role="none">
            {{ firstname }} {{ lastname }}
        </p>
        <p class="text-sm font-medium text-stone-900 truncate dark:text-stone-100" role="none">
            {{ email }}
        </p>
    </div>
    <ul class="py-1" role="none">
        <li>
            <a href="{{ path('finaro_app_dashboard') }}" class="flex items-center px-4 py-2 text-sm text-stone-700 hover:bg-stone-200 dark:text-stone-300 dark:hover:bg-stone-600 dark:hover:text-stone-50" role="menuitem">
                <twig:ux:icon name="mage:dashboard-2" class="w-4 h-4 me-3 text-stone-700 dark:text-stone-300" />
                Dashboard
            </a>
        </li>
        <li>
            <a href="#" class="flex items-center px-4 py-2 text-sm text-stone-700 hover:bg-stone-200 dark:text-stone-300 dark:hover:bg-stone-600 dark:hover:text-stone-50" role="menuitem">
                <twig:ux:icon name="ph:user" class="w-4 h-4 me-3 text-stone-700 dark:text-stone-300" />
                Mes informations
            </a>
        </li>
    </ul>
    <div class="px-4 py-3" role="none">
        <twig:Button:ButtonLink
            class="block"
            color="dark"
            url="{{ path('finaro_logout') }}"
            text="Se déconnecter"
        />
    </div>
</div>