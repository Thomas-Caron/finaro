<div class="{{ containerClass }}">
    {% if label %}
        <label for="{{ id }}" class="block mb-2 text-sm font-medium {% if error %}text-red-700 dark:text-red-500{% else %}text-stone-900 dark:text-stone-50{% endif %}">{{ label }}</label>
    {% endif %}

    <div class="flex {{ class }}">
        <input 
            type="{{ type }}" 
            {% if id %}id="{{ id }}"{% endif %}
            class="
                block w-full p-2.5 text-sm
                {% if 'password' == type %} rounded-none rounded-s-lg{% else %} rounded-lg{% endif %}
                {% if error %} bg-red-50 border border-red-500 text-red-900 placeholder-red-700 focus:ring-red-500 dark:bg-stone-700 focus:border-red-500 dark:text-red-500 dark:placeholder-red-500 dark:border-red-500
                {% else %} bg-stone-50 border border-stone-300 text-stone-900 focus:ring-stone-400 focus:border-stone-400 dark:bg-stone-700 dark:border-stone-500 dark:placeholder-stone-400 dark:text-stone-50 dark:focus:ring-stone-400 dark:focus:border-stone-400
                {% endif %}
                {{ inputClass }}
            "
            name="{{ name }}"
            {% if value %}value="{{ value }}"{% endif %}
            {% if required %}required{% endif %}
            {% if autofocus %}autofocus{% endif %}
            {% if 'password' == type %}
                {{ stimulus_controller('symfony/ux-toggle-password/toggle-password', {
                    visibleLabel: '',
                    hiddenLabel: '',
                    visibleIcon: null,
                    hiddenIcon: null,
                    buttonClasses: ['inline-flex', 'items-center', 'px-3', 'text-sm', 'text-stone-900', 'bg-stone-200', 'border', 'rounded-s-0', 'border-stone-300', 'border-s-0', 'rounded-e-md', 'dark:bg-stone-600', 'dark:text-stone-400', 'dark:border-stone-600'],
                }) }}
            {% endif %}
        >

        {# <span class="inline-flex items-center px-3 text-sm text-gray-900 bg-gray-200 border rounded-s-0 border-gray-300 border-s-0 rounded-e-md dark:bg-gray-600 dark:text-gray-400 dark:border-gray-600">
            <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10 0a10 10 0 1 0 10 10A10.011 10.011 0 0 0 10 0Zm0 5a3 3 0 1 1 0 6 3 3 0 0 1 0-6Zm0 13a8.949 8.949 0 0 1-4.951-1.488A3.987 3.987 0 0 1 9 13h2a3.987 3.987 0 0 1 3.951 3.512A8.949 8.949 0 0 1 10 18Z"/>
            </svg>
        </span> #}
    </div>

    {% if error %}
        <twig:Alert:Alert
            type="error"
            class="mt-3"
            text="{{ this.getError }}"
        />
    {% endif %}
</div>
